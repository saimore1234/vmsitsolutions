// VMS IT Solutions — Enterprise ERP Portal
// Complete data model: identity & RBAC, CMS, CRM/leads, careers, media, settings, logs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Identity & RBAC ───────────────────────────

model User {
  id                  String    @id @default(cuid())
  employeeId          String?   @unique
  email               String    @unique
  username            String?   @unique
  password            String
  firstName           String
  middleName          String?
  lastName            String
  displayName         String?
  phone               String?
  alternatePhone      String?
  avatarUrl           String?
  avatarThumbUrl      String?
  gender              String? // male | female | other | undisclosed
  dob                 DateTime?
  joiningDate         DateTime?
  department          String?
  designation         String?
  location            String?
  bio                 String?
  notes               String?
  language            String?   @default("en")
  timeZone            String?   @default("Asia/Kolkata")
  currency            String?   @default("INR")
  // draft | invited | active | inactive | suspended | locked | deleted | archived
  // isActive/isLocked stay in sync with status and remain the source of truth for requireAuth,
  // so the login/session security path doesn't need to change to understand the richer status field.
  status              String    @default("active")
  isActive            Boolean   @default(true)
  isLocked            Boolean   @default(false)
  emailVerified       Boolean   @default(false)
  mustChangePassword  Boolean   @default(false)
  invitedAt           DateTime?
  invitationToken     String?   @unique
  invitationExpiresAt DateTime?
  lastLoginAt         DateTime?
  tokenVersion        Int       @default(0) // bump to force logout everywhere
  roleId              String
  role                Role      @relation(fields: [roleId], references: [id])
  managerId           String?
  manager             User?     @relation("UserManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports       User[]    @relation("UserManager")
  createdById         String?
  updatedById         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  refreshTokens         RefreshToken[]
  activityLogs          ActivityLog[]
  loginLogs             LoginLog[]
  assignedLeads         Lead[]            @relation("LeadAssignee")
  assignedOpportunities Opportunity[]     @relation("OpportunityAssignee")
  managedCustomers      Customer[]        @relation("CustomerAccountManager")
  managedCrmProjects    CrmProject[]      @relation("CrmProjectManager")
  assignedTickets       SupportTicket[]   @relation("SupportTicketAssignee")
  blogs                 Blog[]
  notifications         Notification[]
  branches              UserBranch[]
  groups                UserGroupMember[]
  documents             UserDocument[]

  @@index([roleId])
  @@index([status])
  @@index([managerId])
  @@map("users")
}

model UserGroup {
  id          String            @id @default(cuid())
  name        String            @unique
  description String?
  members     UserGroupMember[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("user_groups")
}

model UserGroupMember {
  userId  String
  groupId String
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  group   UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@map("user_group_members")
}

model UserBranch {
  userId    String
  branchId  String
  isPrimary Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@map("user_branches")
}

model UserDocument {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind       String // resume | pan | aadhaar | passport | driving_license | offer_letter | certificate | contract | other
  name       String
  url        String
  mimeType   String
  sizeBytes  Int
  uploadedAt DateTime @default(now())

  @@index([userId])
  @@map("user_documents")
}

model Role {
  id          String           @id @default(cuid())
  name        String           @unique // Super Admin, Admin, Manager, Sales, Marketing, HR, Support, Developer, Customer, Guest
  slug        String           @unique
  description String?
  isSystem    Boolean          @default(false) // system roles cannot be deleted
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("roles")
}

model Permission {
  id       String           @id @default(cuid())
  resource String // e.g. "leads", "blogs", "users", "settings"
  action   String // view | create | edit | delete | approve | export | import | print | manage
  roles    RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────── Company & Site Settings ───────────────────────────

model CompanySetting {
  id             String   @id @default("company") // singleton row
  companyName    String   @default("VMS IT Solutions")
  shortName      String   @default("VMS")
  tagline        String?
  address        String?
  city           String?
  state          String?
  country        String?
  pincode        String?
  gstNumber      String?
  panNumber      String?
  cinNumber      String?
  email          String?
  supportEmail   String?
  salesEmail     String?
  phone          String?
  mobile         String?
  whatsapp       String?
  website        String?
  workingHours   String?
  googleMapEmbed String?
  latitude       Float?
  longitude      Float?
  mission        String?
  vision         String?
  description    String?
  history        String?
  ceoMessage     String?
  aboutCompany   String?
  updatedAt      DateTime @updatedAt

  @@map("company_settings")
}

model WebsiteSetting {
  id              String   @id @default("website") // singleton
  siteTitle       String   @default("VMS IT Solutions")
  maintenanceMode Boolean  @default(false)
  gaTrackingId    String?
  fbPixelId       String?
  headScripts     String?
  bodyScripts     String?
  cookieNotice    Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  @@map("website_settings")
}

model ThemeSetting {
  id              String   @id @default("theme") // singleton
  primaryColor    String   @default("#2D5BFF")
  secondaryColor  String   @default("#0A0E1A")
  accentColor     String   @default("#22D3EE")
  bgColor         String   @default("#FFFFFF")
  textColor       String   @default("#0F172A")
  borderRadius    String   @default("12px")
  fontFamily      String   @default("Inter")
  headingFont     String   @default("Space Grotesk")
  baseFontSize    String   @default("16px")
  containerWidth  String   @default("1200px")
  buttonStyle     String   @default("rounded") // rounded | pill | square
  cardStyle       String   @default("shadow") // shadow | border | glass
  navbarStyle     String   @default("glass")
  footerStyle     String   @default("dark")
  darkModeEnabled Boolean  @default(true)
  animations      Boolean  @default(true)
  updatedAt       DateTime @updatedAt

  @@map("theme_settings")
}

model Logo {
  id        String   @id @default(cuid())
  kind      String   @unique
  // primary | dark | light | favicon | login | dashboard | sidebar | mobile | footer | email | invoice |
  // quotation | letterhead | watermark | loader | og_image | default_banner | default_thumbnail
  url       String
  thumbUrl  String? // small preview generated on upload; used in the admin branding grid
  updatedAt DateTime @updatedAt

  @@map("logos")
}

model LogoHistory {
  id        String   @id @default(cuid())
  kind      String
  url       String
  createdAt DateTime @default(now())

  @@index([kind, createdAt])
  @@map("logo_history")
}

model LogoSetting {
  id                  String   @id @default("logo") // singleton
  width               Int      @default(160)
  height              Int      @default(40)
  position            String   @default("left") // left | center | right
  padding             Int      @default(8)
  background          String? // hex or "transparent"
  borderRadius        Int      @default(0)
  headerLogoHeight    Int      @default(40)
  footerLogoHeight    Int      @default(32)
  mobileLogoHeight    Int      @default(32)
  stickyHeaderLogo    Boolean  @default(true)
  darkModeLogoEnabled Boolean  @default(true)
  retinaLogo          Boolean  @default(true)
  enableSvgLogo       Boolean  @default(true)
  maxUploadSizeMb     Int      @default(5)
  updatedAt           DateTime @updatedAt

  @@map("logo_settings")
}

model SmtpSetting {
  id         String   @id @default("smtp") // singleton
  provider   String   @default("smtp") // smtp | sendgrid | mailgun | ses
  host       String?
  port       Int?     @default(587)
  username   String?
  password   String?
  fromEmail  String?
  fromName   String?
  encryption String?  @default("tls")
  updatedAt  DateTime @updatedAt

  @@map("smtp_settings")
}

model CommunicationSetting {
  id                     String   @id @default("communication") // singleton
  notifyEmail            String   @default("sales@vmsitsolutions.com")
  emailEnabled           Boolean  @default(true)
  whatsappNumber         String? // digits only, with country code, e.g. 919137801103
  whatsappDefaultMessage String?  @db.Text // template; supports {{name}} {{email}} {{phone}} {{company}} {{service}} {{message}}
  whatsappEnabled        Boolean  @default(true)
  databaseSaveEnabled    Boolean  @default(true)
  autoRedirectEnabled    Boolean  @default(false)
  thankYouPageEnabled    Boolean  @default(false)
  recaptchaSiteKey       String?
  recaptchaSecretKey     String?
  recaptchaEnabled       Boolean  @default(false)
  updatedAt              DateTime @updatedAt

  @@map("communication_settings")
}

model SocialLink {
  id        String  @id @default(cuid())
  platform  String  @unique // linkedin | facebook | instagram | twitter | youtube
  url       String
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  @@map("social_links")
}

model Language {
  id           String        @id @default(cuid())
  code         String        @unique // en, hi, gu, mr
  name         String
  isDefault    Boolean       @default(false)
  isActive     Boolean       @default(true)
  translations Translation[]

  @@map("languages")
}

model Translation {
  id         String   @id @default(cuid())
  languageId String
  language   Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  key        String
  value      String

  @@unique([languageId, key])
  @@map("translations")
}

model Branch {
  id        String       @id @default(cuid())
  name      String
  kind      String       @default("regional") // head_office | warehouse | regional | support_center
  address   String?
  city      String?
  state     String?
  country   String?
  phone     String?
  email     String?
  latitude  Float?
  longitude Float?
  isActive  Boolean      @default(true)
  sortOrder Int          @default(0)
  users     UserBranch[]

  @@map("branches")
}

// ─────────────────────────── Navigation & CMS ───────────────────────────

model Menu {
  id    String     @id @default(cuid())
  name  String     @unique // header | footer | sidebar
  items MenuItem[]

  @@map("menus")
}

model MenuItem {
  id        String     @id @default(cuid())
  menuId    String
  menu      Menu       @relation(fields: [menuId], references: [id], onDelete: Cascade)
  label     String
  url       String
  target    String     @default("_self")
  parentId  String?
  parent    MenuItem?  @relation("MenuTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  MenuItem[] @relation("MenuTree")
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)

  @@index([menuId])
  @@map("menu_items")
}

model Page {
  id        String        @id @default(cuid())
  title     String
  slug      String        @unique
  status    String        @default("draft") // draft | published
  isLanding Boolean       @default(false)
  sections  PageSection[]
  seo       SeoMeta?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("pages")
}

model PageSection {
  id        String  @id @default(cuid())
  pageId    String
  page      Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)
  kind      String // hero | banner | about | services | products | stats | cta | testimonials | clients | gallery | faq | contact | custom
  // Fully dynamic section content — the admin section builder writes JSON here.
  content   Json
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  @@index([pageId])
  @@map("page_sections")
}

model Banner {
  id        String  @id @default(cuid())
  title     String?
  subtitle  String?
  imageUrl  String?
  videoUrl  String?
  mobileUrl String?
  tabletUrl String?
  ctaLabel  String?
  ctaUrl    String?
  placement String  @default("home_hero") // home_hero | slider | page_banner
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  @@map("banners")
}

model SeoMeta {
  id              String  @id @default(cuid())
  pageId          String? @unique
  page            Page?   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  path            String? @unique // for non-CMS routes, e.g. "/services"
  metaTitle       String?
  metaDescription String?
  keywords        String?
  canonical       String?
  schemaJson      Json?
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  twitterCard     String? @default("summary_large_image")
  robots          String? @default("index,follow")

  @@map("seo")
}

// ─────────────────────────── Media Library ───────────────────────────

model MediaFolder {
  id       String        @id @default(cuid())
  name     String
  parentId String?
  parent   MediaFolder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children MediaFolder[] @relation("FolderTree")
  files    Media[]

  @@map("media_folders")
}

model Media {
  id        String       @id @default(cuid())
  name      String
  fileName  String
  mimeType  String
  sizeBytes Int
  url       String
  kind      String // image | video | pdf | doc | sheet | slide | svg | icon | other
  folderId  String?
  folder    MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt DateTime     @default(now())

  @@index([folderId])
  @@map("media")
}

// ─────────────────────────── Blog ───────────────────────────

model Blog {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  excerpt         String?
  content         String
  featuredImage   String?
  status          String        @default("draft") // draft | scheduled | published
  publishAt       DateTime?
  views           Int           @default(0)
  likes           Int           @default(0)
  authorId        String
  author          User          @relation(fields: [authorId], references: [id])
  categoryId      String?
  category        BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags            BlogTag[]
  comments        BlogComment[]
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status, publishAt])
  @@map("blogs")
}

model BlogCategory {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  blogs Blog[]

  @@map("blog_categories")
}

model BlogTag {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  blogs Blog[]

  @@map("blog_tags")
}

model BlogComment {
  id        String   @id @default(cuid())
  blogId    String
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  name      String
  email     String
  content   String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([blogId])
  @@map("blog_comments")
}

// ─────────────────────────── Catalog: Services / Products / Industries ───────────────────────────

model ServiceCategory {
  id       String            @id @default(cuid())
  name     String            @unique
  slug     String            @unique
  parentId String?
  parent   ServiceCategory?  @relation("ServiceCatTree", fields: [parentId], references: [id], onDelete: SetNull)
  children ServiceCategory[] @relation("ServiceCatTree")
  services Service[]

  @@map("service_categories")
}

model Service {
  id              String           @id @default(cuid())
  name            String
  slug            String           @unique
  shortDesc       String?
  description     String?
  icon            String?
  bannerUrl       String?
  gallery         Json? // array of media urls
  price           Decimal?         @db.Decimal(12, 2)
  categoryId      String?
  category        ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  metaTitle       String?
  metaDescription String?
  isActive        Boolean          @default(true)
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("services")
}

model Product {
  id              String   @id @default(cuid())
  name            String // ERPNext, SAP Business One, CRM, HRMS, Inventory, Manufacturing, Accounting, Payroll, Projects, Asset, Quality, Purchase, Sales
  slug            String   @unique
  shortDesc       String?
  description     String?
  icon            String?
  bannerUrl       String?
  features        Json? // array of feature strings
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("products")
}

model Industry {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  icon        String?
  imageUrl    String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  @@map("industries")
}

// ─────────────────────────── People & Social Proof ───────────────────────────

model TeamMember {
  id          String  @id @default(cuid())
  name        String
  designation String
  department  String?
  photoUrl    String?
  experience  String?
  skills      Json?
  linkedin    String?
  email       String?
  phone       String?
  bio         String?
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  @@map("team")
}

model Client {
  id          String    @id @default(cuid())
  name        String
  logoUrl     String?
  industry    String?
  description String?
  website     String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  projects    Project[]

  @@map("clients")
}

model Project {
  id        String  @id @default(cuid())
  title     String
  slug      String  @unique
  clientId  String?
  client    Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  summary   String?
  caseStudy String?
  imageUrl  String?
  isActive  Boolean @default(true)

  @@map("projects")
}

model Testimonial {
  id        String  @id @default(cuid())
  name      String
  company   String?
  role      String?
  photoUrl  String?
  content   String
  rating    Int     @default(5)
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  @@map("testimonials")
}

model Faq {
  id        String  @id @default(cuid())
  question  String
  answer    String
  category  String?
  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  @@map("faq")
}

model GalleryItem {
  id        String  @id @default(cuid())
  title     String?
  imageUrl  String
  album     String?
  sortOrder Int     @default(0)

  @@map("gallery")
}

// ─────────────────────────── Careers ───────────────────────────

model Career {
  id           String        @id @default(cuid())
  title        String
  slug         String        @unique
  department   String?
  location     String?
  jobType      String        @default("full_time") // full_time | part_time | contract | remote
  experience   String?
  salaryRange  String?
  description  String
  requirements String?
  status       String        @default("open") // open | closed
  applications Application[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("careers")
}

model Application {
  id        String   @id @default(cuid())
  careerId  String
  career    Career   @relation(fields: [careerId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String?
  resumeUrl String?
  coverNote String?
  status    String   @default("received") // received | screening | interview | offered | rejected | hired
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([careerId, status])
  @@map("applications")
}

// ─────────────────────────── CRM / Leads ───────────────────────────

model Lead {
  id           String       @id @default(cuid())
  name         String
  email        String?
  phone        String?
  company      String?
  message      String?
  source       String       @default("website") // website | contact | demo | quote | newsletter | referral | manual
  kind         String       @default("contact") // contact | demo | quote | general
  status       String       @default("new") // new | contacted | qualified | proposal | won | lost
  assignedToId String?
  assignedTo   User?        @relation("LeadAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  remarks      LeadRemark[]
  reminderAt   DateTime?
  meta         Json? // product interest, budget, page URL, UTM, etc.
  ipAddress    String?
  userAgent    String?
  country      String? // populated only if a GeoIP source is wired up; not set by default
  opportunity  Opportunity?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status, source])
  @@index([assignedToId])
  @@map("lead")
}

model LeadRemark {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String?
  content   String
  createdAt DateTime @default(now())

  @@index([leadId])
  @@map("lead_remarks")
}

// ─────────────────────────── CRM / Sales Pipeline ───────────────────────────
// Website Lead -> Lead Qualification -> Opportunity -> Quotation -> Negotiation -> Won -> Customer -> Projects / Support / AMC

model Opportunity {
  id                String              @id @default(cuid())
  title             String
  leadId            String?             @unique
  lead              Lead?               @relation(fields: [leadId], references: [id], onDelete: SetNull)
  company           String?
  contactName       String?
  contactEmail      String?
  contactPhone      String?
  stage             String              @default("qualification") // qualification | quotation | negotiation | won | lost
  value             Decimal?            @db.Decimal(12, 2)
  currency          String              @default("INR")
  probability       Int                 @default(10)
  expectedCloseDate DateTime?
  assignedToId      String?
  assignedTo        User?               @relation("OpportunityAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  lostReason        String?
  wonAt             DateTime?
  quotations        Quotation[]
  remarks           OpportunityRemark[]
  customer          Customer?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([stage])
  @@index([assignedToId])
  @@map("opportunities")
}

model OpportunityRemark {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  authorId      String?
  content       String
  createdAt     DateTime    @default(now())

  @@index([opportunityId])
  @@map("opportunity_remarks")
}

model Quotation {
  id              String          @id @default(cuid())
  quotationNumber String          @unique
  opportunityId   String
  opportunity     Opportunity     @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  items           QuotationItem[]
  subtotal        Decimal         @default(0) @db.Decimal(12, 2)
  discount        Decimal         @default(0) @db.Decimal(12, 2)
  tax             Decimal         @default(0) @db.Decimal(12, 2)
  total           Decimal         @default(0) @db.Decimal(12, 2)
  currency        String          @default("INR")
  status          String          @default("draft") // draft | sent | accepted | rejected | expired
  validUntil      DateTime?
  notes           String?
  sentAt          DateTime?
  respondedAt     DateTime?
  createdById     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([opportunityId, status])
  @@map("quotations")
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  description String
  quantity    Decimal   @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal   @db.Decimal(12, 2)
  amount      Decimal   @db.Decimal(12, 2)
  sortOrder   Int       @default(0)

  @@index([quotationId])
  @@map("quotation_items")
}

model Customer {
  id               String          @id @default(cuid())
  opportunityId    String?         @unique
  opportunity      Opportunity?    @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  companyName      String
  contactName      String?
  email            String?
  phone            String?
  billingAddress   String?
  shippingAddress  String?
  gstNumber        String?
  panNumber        String?
  accountManagerId String?
  accountManager   User?           @relation("CustomerAccountManager", fields: [accountManagerId], references: [id], onDelete: SetNull)
  status           String          @default("active") // active | inactive | churned
  crmProjects      CrmProject[]
  supportTickets   SupportTicket[]
  amcContracts     AmcContract[]
  convertedAt      DateTime        @default(now())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([status])
  @@index([accountManagerId])
  @@map("customers")
}

model CrmProject {
  id               String    @id @default(cuid())
  customerId       String
  customer         Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  status           String    @default("planning") // planning | in_progress | on_hold | completed | cancelled
  budget           Decimal?  @db.Decimal(12, 2)
  currency         String    @default("INR")
  startDate        DateTime?
  endDate          DateTime?
  projectManagerId String?
  projectManager   User?     @relation("CrmProjectManager", fields: [projectManagerId], references: [id], onDelete: SetNull)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([customerId, status])
  @@map("customer_projects")
}

model SupportTicket {
  id           String    @id @default(cuid())
  customerId   String
  customer     Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  subject      String
  description  String?
  priority     String    @default("medium") // low | medium | high | urgent
  status       String    @default("open") // open | in_progress | resolved | closed
  assignedToId String?
  assignedTo   User?     @relation("SupportTicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  resolvedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([customerId, status])
  @@index([assignedToId])
  @@map("support_tickets")
}

model AmcContract {
  id                String    @id @default(cuid())
  customerId        String
  customer          Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contractNumber    String    @unique
  startDate         DateTime
  endDate           DateTime
  value             Decimal?  @db.Decimal(12, 2)
  currency          String    @default("INR")
  status            String    @default("active") // active | expired | cancelled | renewed
  renewalReminderAt DateTime?
  terms             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([customerId, status])
  @@map("amc_contracts")
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@map("newsletter")
}

// ─────────────────────────── Popup Builder ───────────────────────────

model Popup {
  id            String    @id @default(cuid())
  name          String // internal label shown in the admin list
  type          String    @default("announcement") // announcement | newsletter | offer | discount | exit_intent | lead_capture | cookie_consent | download_brochure | book_demo | whatsapp | schedule
  title         String?
  content       String?
  imageUrl      String?
  ctaText       String?
  ctaUrl        String?
  isActive      Boolean   @default(true)
  trigger       String    @default("delay") // immediate | delay | scroll | exit_intent
  delaySeconds  Int       @default(5)
  scrollPercent Int       @default(50)
  frequency     String    @default("session") // always | session | day | once
  pageRules     Json? // array of path globs the popup is allowed on; empty/null = all pages
  deviceRules   Json? // array of "desktop" | "mobile" | "tablet"; empty/null = all devices
  priority      Int       @default(0) // higher priority shown first when multiple popups match
  startAt       DateTime?
  endAt         DateTime?
  views         Int       @default(0)
  dismissals    Int       @default(0)
  conversions   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isActive, startAt, endAt])
  @@map("popups")
}

// ─────────────────────────── Logs, Analytics, Notifications ───────────────────────────

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String // created | updated | deleted | exported | login | logout ...
  resource   String
  resourceId String?
  detail     Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([resource, createdAt])
  @@map("activity_logs")
}

model LoginLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email     String
  success   Boolean
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@map("login_logs")
}

model ErrorLog {
  id         String   @id @default(cuid())
  message    String
  stack      String?
  path       String?
  method     String?
  statusCode Int?
  createdAt  DateTime @default(now())

  @@map("error_logs")
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([path, createdAt])
  @@map("analytics")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String?
  kind      String    @default("info") // info | lead | application | system
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@map("notifications")
}
