JWT_ACCESS_SECRET=generate-a-long-random-string
JWT_REFRESH_SECRET=generate-another-long-random-string
CORS_ORIGIN=http://localhost:3000
PUBLIC_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Cloudflare R2 (S3-compatible object storage) — uploaded files (logos, media library,
# avatars, documents) are stored here instead of local disk, which doesn't survive
# restarts/redeploys on most hosting platforms.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Sentry error tracking. Leave blank to disable (both SDKs no-op without a DSN).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
